# Server
BACKEND_PORT=8081
FRONTEND_PORT=4300
SERVER_PORT=8081

# PostgreSQL
POSTGRES_DB=erp_pymes
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_PORT=5432

# Spring datasource
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/erp_pymes
SPRING_DATASOURCE_USERNAME=erp_user
SPRING_DATASOURCE_PASSWORD=change-me-postgres-password

# Redis
SPRING_CACHE_TYPE=redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT: use at least 32 bytes and never commit production values
JWT_SECRET=change-this-secret-to-a-real-32-byte-minimum-value
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Security / API docs
APP_CORS_ALLOWED_ORIGINS=http://localhost:4300
APP_SWAGGER_ENABLED=true
APP_LOCAL_BOOTSTRAP_ENABLED=true
